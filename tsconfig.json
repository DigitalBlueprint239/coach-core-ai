{
  "compilerOptions": {
    "target": "es2016",
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/coach-core-ai/**",
    "src/components/SmartPlaybook/src/**",
    "src/components/Coach's Corner/**",
    "src/components/Coach Core AI Brain /**",
    "src/components/coach-core-backend.ts",
    "src/utils/offline-persistence.ts",
    "src/components/coach-core-integration.ts",
    "src/utils/**"
  ]
}