{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/components/coach-core-integration.ts",
    "src/components/coach-core-integration.tsx",
    "src/components/coach-core-backend.ts",
    "src/components/coach-core-complete-integration.tsx",
    "src/coach-core-ai/coach-core-complete.tsx",
    "src/components/fixed-core-functionality.tsx",
    "src/components/SmartPlaybook/src/**/*",
    "src/components/SmartPlaybook/components/PlayerControls.js",
    "src/components/SmartPlaybook/components/RouteControls.js",
    "src/components/SmartPlaybook/components/RouteEditor.js",
    "src/components/SmartPlaybook/components/FormationTemplates.js",
    "src/components/SmartPlaybook/components/SaveLoadPanel.js",
    "src/components/SmartPlaybook/components/Toolbar.js",
    "src/components/SmartPlaybook/components/Notification.js",
    "src/components/SmartPlaybook/components/Onboarding.js",
    "src/components/SmartPlaybook/Field.js",
    "src/components/SmartPlaybook/DebugPanel.js",
    "src/components/SmartPlaybook/PlayLibrary.js",
    "src/components/SmartPlaybook/PlayController.js",
    "src/components/SmartPlaybook/:components:SmartPlaybook:Field.js",
    "src/utils/data-validation.ts",
    "src/utils/performance-testing.ts",
    "src/utils/offline-persistence.ts",
    "src/utils/performance-optimization.ts",
    "src/utils/data-migration.ts",
    "src/components/OfflineFallbacks.tsx"
  ]
}
