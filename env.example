# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_STRIPE_SECRET_KEY=sk_test_your_secret_key
VITE_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App Configuration
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=Coach Core AI
VITE_APP_VERSION=1.0.0

# Analytics Configuration
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GA4_API_SECRET=your_ga4_api_secret
VITE_SENTRY_DSN=your_sentry_dsn

# BigQuery Configuration
VITE_BIGQUERY_PROJECT_ID=your_bigquery_project_id
VITE_BIGQUERY_DATASET_ID=coach_core_analytics
VITE_BIGQUERY_TABLE_ID=events

# Looker Studio Configuration
VITE_LOOKER_STUDIO_DASHBOARD_ID=your_dashboard_id
VITE_LOOKER_STUDIO_EMBED_URL=https://lookerstudio.google.com/embed/reporting/your_dashboard_id

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=true
VITE_ENABLE_STRIPE=true
VITE_ENABLE_BETA_FEATURES=false

# Recruiting Hub Feature Flag
VITE_FEATURE_RECRUITING=true

# Recruiting Hub Configuration
VITE_PUBLIC_APP_URL=http://localhost:3000
RECRUITING_WEBHOOK_SECRET=replace-with-secure-secret
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
YOUTUBE_API_KEY=your_youtube_api_key
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
HUDL_INTEGRATION_MODE=manual   # manual | partner | extension
MAXPREPS_INTEGRATION_MODE=manual
OPENAI_API_KEY=your_openai_api_key
