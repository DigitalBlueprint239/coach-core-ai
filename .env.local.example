# .env.local.example
# Copy this file to .env.local and replace with your actual Firebase project values.
#
# WHY REACT_APP_ PREFIX:
# This project uses Create React App (react-scripts). CRA only injects environment
# variables that start with REACT_APP_ into the client bundle at build time.
# NEXT_PUBLIC_ is Next.js syntax. VITE_ is Vite syntax. Neither works here.
#
# HOW TO SET UP:
#   cp .env.local.example .env.local
#   # Then edit .env.local with your Firebase project values from:
#   # Firebase Console > Project Settings > Your apps > SDK setup and configuration

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id_here
