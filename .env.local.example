# Firebase Configuration (Vite)
# Copy this file to .env.local and replace with your actual Firebase project values
# Vite requires all client-side env vars to be prefixed with VITE_

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Optional: set to 'true' to connect to local Firebase emulators during development
VITE_USE_EMULATOR=false

# Example values for reference (DO NOT USE IN PRODUCTION):
# VITE_FIREBASE_API_KEY=AIzaSyB2iWL0UkuLJYpr-II9IpwGWDOMnLcfq_c
# VITE_FIREBASE_AUTH_DOMAIN=coach-core-ai.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=coach-core-ai
# VITE_FIREBASE_STORAGE_BUCKET=coach-core-ai.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=384023691487
# VITE_FIREBASE_APP_ID=1:384023691487:web:931094d7a0da903d6e696a
# VITE_FIREBASE_MEASUREMENT_ID=G-02HW7QDJLY